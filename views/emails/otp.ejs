<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your OTP - Box Cricket</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;font-family:Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f4;padding:40px 0;">
    <tr>
      <td align="center">

        <table width="520" cellpadding="0" cellspacing="0"
               style="background-color:#ffffff;border-radius:8px;overflow:hidden;
                      box-shadow:0 2px 8px rgba(0,0,0,0.08);">

          <tr>
            <td style="background-color:#1a7a4a;padding:28px 40px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:22px;letter-spacing:1px;">
                Box Cricket
              </h1>
            </td>
          </tr>

          <tr>
            <td style="padding:40px 40px 32px;">

              <p style="margin:0 0 12px;font-size:16px;color:#333333;">
                Hi <strong><%= name %></strong>,
              </p>

              <p style="margin:0 0 28px;font-size:15px;color:#555555;line-height:1.6;">
                Use the OTP below to verify your mobile number and continue.
              </p>

              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <div style="display:inline-block;background-color:#f0faf5;border:2px dashed #1a7a4a;
                                border-radius:8px;padding:20px 48px;margin-bottom:28px;">
                      <span style="font-size:42px;font-weight:bold;letter-spacing:10px;
                                   color:#1a7a4a;font-family:'Courier New',monospace;">
                        <%= otp %>
                      </span>
                    </div>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 8px;font-size:14px;color:#e05c00;font-weight:bold;text-align:center;">
                Valid for 10 minutes only.
              </p>
              <p style="margin:0 0 28px;font-size:14px;color:#777777;text-align:center;">
                Do not share this OTP with anyone.
              </p>

            </td>
          </tr>

          <tr>
            <td style="background-color:#f9f9f9;padding:20px 40px;
                       border-top:1px solid #eeeeee;text-align:center;">
              <p style="margin:0;font-size:12px;color:#aaaaaa;">
                Box Cricket - All rights reserved.
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
