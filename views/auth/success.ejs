<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Logged In - Box Cricket</title>
  <link rel="stylesheet" href="/mobile/v1/auth/test/styles.css" />
</head>
<body>
  <main class="shell">
    <section class="panel">
      <h1>Logged In</h1>
      <% if (message) { %><div class="notice"><%= message %></div><% } %>
      <% if (error) { %><div class="error"><%= error %></div><% } %>

      <div class="status">
        <span>accessToken: <strong><%= cookies.hasAccessToken ? 'Present' : 'Not present' %></strong></span>
        <span>refreshToken: <strong><%= cookies.hasRefreshToken ? 'Present' : 'Not present' %></strong></span>
      </div>

      <% if (user) { %>
        <dl>
          <dt>Name</dt>
          <dd><%= user.name %></dd>
          <dt>Phone</dt>
          <dd><%= user.phone %></dd>
          <dt>Role</dt>
          <dd><%= user.role %></dd>
          <dt>Verified</dt>
          <dd><%= user.isVerified ? 'Yes' : 'No' %></dd>
        </dl>
      <% } %>

      <div class="actions">
        <form method="post" action="/mobile/v1/auth/test/refresh">
          <button class="secondary" type="submit">Refresh Access Token</button>
        </form>
        <form method="post" action="/mobile/v1/auth/test/logout">
          <button class="danger" type="submit">Logout</button>
        </form>
      </div>
    </section>
  </main>
</body>
</html>
