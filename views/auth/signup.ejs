<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign Up - Box Cricket</title>
  <link rel="stylesheet" href="/mobile/v1/auth/test/styles.css" />
</head>
<body>
  <main class="shell compact">
    <section class="panel">
      <a class="back" href="/mobile/v1/auth/test">Back</a>
      <h1>Sign Up</h1>
      <p class="muted">Create your account with mobile OTP.</p>

      <% if (message) { %><div class="notice"><%= message %></div><% } %>
      <% if (error) { %><div class="error"><%= error %></div><% } %>

      <form method="post" action="/mobile/v1/auth/test/signup">
        <label for="name">Name</label>
        <input id="name" name="name" value="Yash" required />

        <label for="phone">Mobile Number</label>
        <input
          id="phone"
          name="phone"
          value="<%= phone || '' %>"
          inputmode="numeric"
          minlength="10"
          maxlength="10"
          pattern="[6-9][0-9]{9}"
          title="Enter a 10-digit Indian mobile number"
          required
        />

        <button type="submit">Send OTP</button>
      </form>

      <p class="switch">Already registered? <a href="/mobile/v1/auth/test/login">Login</a></p>
    </section>
  </main>
</body>
</html>
