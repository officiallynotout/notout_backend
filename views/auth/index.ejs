<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Box Cricket Auth</title>
  <link rel="stylesheet" href="/mobile/v1/auth/test/styles.css" />
</head>
<body>
  <main class="shell compact">
    <section class="panel">
      <h1>Box Cricket</h1>
      <p class="muted">Choose how you want to continue.</p>

      <% if (message) { %><div class="notice"><%= message %></div><% } %>
      <% if (error) { %><div class="error"><%= error %></div><% } %>

      <div class="actions">
        <a class="button" href="/mobile/v1/auth/test/login">Login</a>
        <a class="button secondary" href="/mobile/v1/auth/test/signup">Sign Up</a>
      </div>

      <div class="status">
        <span>accessToken: <strong><%= cookies.hasAccessToken ? 'Present' : 'Not present' %></strong></span>
        <span>refreshToken: <strong><%= cookies.hasRefreshToken ? 'Present' : 'Not present' %></strong></span>
      </div>
    </section>
  </main>
</body>
</html>
