<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Box Cricket</title>
  <link rel="stylesheet" href="/mobile/v1/auth/test/styles.css" />
</head>
<body>
  <main class="shell compact">
    <section class="panel">
      <a class="back" href="/mobile/v1/auth/test">Back</a>
      <h1>Login</h1>
      <p class="muted">Enter your mobile number to receive OTP.</p>

      <% if (message) { %><div class="notice"><%= message %></div><% } %>
      <% if (error) { %><div class="error"><%= error %></div><% } %>

      <form method="post" action="/mobile/v1/auth/test/login">
        <label for="phone">Mobile Number</label>
        <input
          id="phone"
          name="phone"
          value="<%= phone || '' %>"
          inputmode="numeric"
          minlength="10"
          maxlength="10"
          pattern="[6-9][0-9]{9}"
          title="Enter a 10-digit Indian mobile number"
          required
        />

        <button type="submit">Send OTP</button>
      </form>

      <p class="switch">New user? <a href="/mobile/v1/auth/test/signup">Sign up</a></p>
    </section>
  </main>
</body>
</html>
