PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/notout
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
CRYPTO_SECRET=your_crypto_secret_min_32_chars
